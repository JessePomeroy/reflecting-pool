# ============================================================================
# reflecting-pool — Environment Variables
# ============================================================================
# Copy this file to .env.local (for dev) and set real values.
# NEVER commit a file named .env or .env.production with real secrets.
# `.gitignore` already excludes .env*, but the generic filename is a footgun.
#
# In production, all of these must be set in Vercel → Settings → Environment
# Variables AND in Convex → `npx convex env set <NAME> <VALUE>` (for the subset
# read by Convex functions, marked [convex] below).
# ============================================================================

# ----- Site -----
PUBLIC_SITE_URL=http://localhost:5173

# ----- Convex -----
# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev:your-deployment-slug
PUBLIC_CONVEX_URL=https://your-deployment-slug.convex.cloud
PUBLIC_CONVEX_SITE_URL=https://your-deployment-slug.convex.site

# ----- Better Auth [convex] -----
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
AUTH_SECRET=
# Must match the deployed site's URL (used by the auth handler to build callback URLs)
SITE_URL=http://localhost:5173
# Google OAuth (Better Auth social provider)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ----- Webhook auth [convex] -----
# Shared secret between the SvelteKit webhook handlers and the Convex
# mutations they call. Gates orders.create / orders.updateStatus /
# platform.updateSubscription / platform.getBySubscriptionId /
# invoices.markPaid (audit C4 / C6 / C7).
# Generate with: openssl rand -base64 32
# ALSO run: npx convex env set WEBHOOK_SECRET <value>
WEBHOOK_SECRET=

# ----- Sanity CMS -----
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production
# Writeable token used by the Stripe webhook to create/patch `order` docs.
SANITY_API_TOKEN=

# ----- Stripe -----
# Use sk_test_... / pk_test_... locally. Use sk_live_... / pk_live_... only in
# production deployment. Never commit either.
STRIPE_SECRET_KEY=sk_test_xxx
PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxx
# Webhook signing secret from the Stripe dashboard → webhook endpoint.
STRIPE_WEBHOOK_SECRET=

# ----- Resend (transactional email) -----
RESEND_API_KEY=
# Email addresses for order notifications. Required in prod; dev falls
# back to the developer's domain (audit H2).
ADMIN_EMAIL=
FROM_EMAIL=

# ----- LumaPrints (print fulfillment) -----
LUMAPRINTS_API_KEY=
LUMAPRINTS_API_SECRET=
LUMAPRINTS_STORE_ID=
# Set to "true" to route all LumaPrints API calls through the sandbox endpoint.
LUMAPRINTS_USE_SANDBOX=true
# Webhook verification (audit C9). Use either HMAC signing or a shared token
# — either is enough to pass `verifyCaller` in the webhook handler.
# Generate with: openssl rand -base64 32
LUMAPRINTS_WEBHOOK_SIGNING_SECRET=
LUMAPRINTS_WEBHOOK_SECRET=

# ----- Gallery Worker (Cloudflare Worker for R2 uploads) -----
# Per-tenant Worker instance. Defaults to the creator's worker in dev;
# required (fail-closed) in prod.
GALLERY_WORKER_URL=https://gallery-worker.your-subdomain.workers.dev
# Secret used to authenticate admin upload / presign requests to the worker.
# Rotate separately per repo — this is NOT the same as angelsrest's copy.
GALLERY_ADMIN_SECRET=

# ----- Sentry -----
# Optional. Leave empty to disable error capture entirely (no-op).
# Audit H39: install once configured; source-map upload needs the auth token
# set in CI (not in runtime env).
PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
